# Channels — fill what you want to enable. Leave others empty to skip.

# ntfy.sh — pick a unique secret topic name (no registration needed).
# Subscribe in the ntfy mobile app to the same topic to receive pushes.
NTFY_TOPIC=

# Optional: self-hosted ntfy server. Leave blank to use the public ntfy.sh.
NTFY_SERVER=https://ntfy.sh

# Email via SMTP (Gmail recommended — generate an "App password").
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_TO=

# Telegram bot — optional second channel.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord webhook — optional.
DISCORD_WEBHOOK_URL=
